{
  "name": "aether-plain-docs",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "sync": "node scripts/sync-content.mjs",
    "build": "npm run sync && node scripts/build-docs.mjs",
    "check": "npm run build",
    "dev": "npm run build && wrangler dev",
    "preview": "npm run build && wrangler dev",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:worker": "vitest run --config vitest.workers.config.js"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@vitest/coverage-v8": "^4.1.10",
    "fast-glob": "^3.3.3",
    "github-slugger": "^2.0.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
