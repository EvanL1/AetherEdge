      "attribution": false
    },
    {
      "id": "site-zh-cn",
      "label": "AetherIoT 中文文档",
      "root": ".",
      "manifest": "content.zh-cn.manifest.txt",
      "destinationPrefix": "",
      "stripPrefix": "locales/zh-CN/",
      "githubBlobBase": "https://github.com/EvanL1/AetherEdge/blob/main/docs-site/locales/zh-CN",
      "attribution": false
    }
  ]
