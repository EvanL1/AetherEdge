# Rust build artifacts - exclude heavy intermediate artifacts, keep release binaries
target/**/deps/
target/**/build/
target/**/.fingerprint/
target/**/incremental/
target/**/examples/
target/debug/
target/doc/
target/.rustc_info.json
target/.cargo-lock
**/*.rs.bk
*.pdb

# Cargo lock for libraries (keep for binaries)
# Cargo.lock

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore
.gitattributes

# CI/CD
.github/

# Documentation
*.md
!README.md
docs/
# The aether CLI compiles these pages into the MCP binary (include_str! in
# tools/aether/src/mcp_docs.rs); Dockerfile.mcp builds from source and needs
# them in the context.
!docs/concepts/architecture.md
!docs/concepts/data-model.md
!docs/concepts/shared-memory.md
!docs/concepts/rule-engine.md
!docs/concepts/data-flow.md
!docs/guides/ai-assistants.md
!docs/reference/mcp-tools.md

# Test files
tests/
benches/

# Build outputs
build/
# The installer builder injects one target-specific, checksummed composition
# artifact into the otherwise ignored build tree. Keep every other build
# output excluded from the Docker context.
!build/
build/*
!build/installer/
build/installer/*
!build/installer/runtime/
build/installer/runtime/*
!build/installer/runtime/runtime-manifest.json
dist/
release/
offline-bundle/

# Logs
*.log
logs/

# Database files
*.db
*.db-shm
*.db-wal
data/

# Node.js (for apps/)
node_modules/
npm-debug.log
yarn-error.log
.pnpm-debug.log

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
env/

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.cache

# Docker
.dockerignore
Dockerfile*
docker-compose*.yml
docker/

# Scripts (not needed in image)
scripts/

# Development tools
.env
.env.local
.env.*.local
