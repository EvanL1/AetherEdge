[Unit]
Description=Aether Edge uplink service (aether-uplink)
PartOf=aether.target

[Service]
Type=simple
EnvironmentFile=/etc/aether/aether.env
Environment=API_HOST=127.0.0.1
ExecStart=/opt/aether/bin/aether-uplink
Restart=on-failure
RestartSec=2
User=root
WorkingDirectory=/opt/aether

[Install]
WantedBy=aether.target
