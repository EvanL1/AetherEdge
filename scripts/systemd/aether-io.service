[Unit]
Description=Aether Edge device I/O (aether-io)
PartOf=aether.target

[Service]
Type=simple
EnvironmentFile=/etc/aether/aether.env
ExecStart=/opt/aether/bin/aether-io --bind-address 127.0.0.1:6001
Restart=on-failure
RestartSec=2
User=root
WorkingDirectory=/opt/aether

[Install]
WantedBy=aether.target
