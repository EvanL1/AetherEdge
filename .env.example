# AetherEMS Docker Environment Variables
# Copy this file to .env and customize for your environment:
#   cp .env.example .env

# ============================================
# Path Configuration
# ============================================

# Base path for Aether site configuration and databases
# Default: ./data (relative to docker-compose.yml)
# Production example: /opt/aetherems
AETHER_BASE_PATH=./data

# ============================================
# User/Group IDs (for Linux file permissions)
# ============================================

# User ID and Group ID for container processes
# These MUST match your host user to avoid permission issues
#
# Auto-detection (recommended):
#   Run: id -u    # Get your UID
#   Run: id -g    # Get your GID
#
# Common defaults by OS:
#   macOS:  UID=501 (first user), GID=20 (staff group)
#   Linux:  UID=1000 (first user), GID=1000
HOST_UID=1000
HOST_GID=1000

# Dialout group for serial port access (Linux only)
# Get your system's dialout GID with: getent group dialout
DIALOUT_GID=20

# ============================================
# Service URLs (usually no need to change)
# ============================================

# Optional InfluxDB history adapter (not used by the default runtime)
# INFLUXDB_URL=http://127.0.0.1:8181
# INFLUXDB_ORG=aether          # InfluxDB 2.x legacy; 3.x does not use org
# INFLUXDB_BUCKET=history      # InfluxDB 2.x legacy; 3.x uses database name
# INFLUXDB_TOKEN=  # Set after initial InfluxDB setup
# INFLUXDB_PASSWORD=  # Generate with: openssl rand -base64 32

# Internal service URLs (for api and aether CLI)
# Public gateway bind; set 127.0.0.1 when no remote client should connect.
AETHER_API_HOST=0.0.0.0
AETHER_IO_URL=http://127.0.0.1:6001
AETHER_AUTOMATION_URL=http://127.0.0.1:6002
AETHER_HISTORY_URL=http://127.0.0.1:6004
AETHER_API_URL=http://127.0.0.1:6005
AETHER_UPLINK_URL=http://127.0.0.1:6006
AETHER_ALARM_URL=http://127.0.0.1:6007

# aether-uplink durable local queue
AETHER_UPLINK_OUTBOX_PATH=./data/uplink.outbox
AETHER_UPLINK_OUTBOX_CAPACITY=10000

# ============================================
# Path Configuration (for aether CLI)
# ============================================

# Override auto-detected config and data paths
# These take precedence over auto-detection logic
# AETHER_CONFIG_PATH=/opt/AetherEdge/data/config
# AETHER_DATA_PATH=/opt/AetherEdge/data
# AETHER_TIMESCALE_DATA_PATH=./data/timescaledb/data
# AETHER_INSTALL_CONTEXT_PATH=/etc/aether/install.yaml

# Optional shared-memory overrides. The defaults select the platform tmpfs,
# derive the sibling health segment, and refresh coherent SQLite topology once
# per second. Keep the refresh interval at or above 100 ms.
# AETHER_SHM_PATH=/dev/shm/aether-rtdb.shm
# AETHER_CHANNEL_HEALTH_SHM_PATH=/dev/shm/aether-rtdb-health.shm
# SHM_WRITER_STALE_AFTER_MS=30000
# SHM_IDENTITY_CHECK_INTERVAL_MS=250
# SHM_TOPOLOGY_REFRESH_INTERVAL_MS=1000

# Optional request-driven Load-Forecasting processor. Production uses the
# explicit deploy/docker-compose.data-processing.yaml override; the default
# runtime never pulls or starts the image and Data Processing remains disabled.
# AETHER_DATA_PROCESSING_ENABLED=false
# AETHER_LOAD_FORECASTING_BEARER_TOKEN=  # generate a distinct random secret
# AETHER_LOAD_FORECASTING_MAX_CONCURRENCY=1
# AETHER_LOAD_FORECASTING_ARTIFACT_BUNDLES=[...strict commissioned bundle JSON...]
# AETHER_LOAD_FORECASTING_IMAGE=registry.example/load-forecasting@sha256:<digest>
# AETHER_LOAD_FORECASTING_PORT=8989

# ============================================
# Home Assistant (optional, installer feature-gated)
# ============================================

# The official release artifacts do not currently compile these features.
# A custom installer built with --io-features may include them, but every
# runtime path remains disabled until its own switch is set to true.
AETHER_HOME_ASSISTANT_ENABLED=false
AETHER_HOME_ASSISTANT_CLOUDLINK_ENABLED=false
AETHER_HOME_ASSISTANT_CONTROL_ENABLED=false

# Local Home Assistant projection. Compose fixes the token reference to
# env:AETHER_HOME_ASSISTANT_TOKEN inside aether-io.
AETHER_HOME_ASSISTANT_ORIGIN=
AETHER_HOME_ASSISTANT_TOKEN=
AETHER_GATEWAY_ID=
AETHER_HOME_ASSISTANT_INTEGRATION_ID=home-assistant

# Optional CloudLink publication. Compose fixes the public/signing key and
# broker password references to the three value variables below.
AETHER_HOME_ASSISTANT_CLOUDLINK_ORIGIN_MODEL=
AETHER_HOME_ASSISTANT_CLOUDLINK_CLOUD_KEY_ID=
AETHER_HOME_ASSISTANT_CLOUDLINK_CLOUD_PUBLIC_KEY=
AETHER_HOME_ASSISTANT_CLOUDLINK_GATEWAY_KEY_ID=
AETHER_HOME_ASSISTANT_CLOUDLINK_GATEWAY_SIGNING_KEY=
AETHER_HOME_ASSISTANT_CLOUDLINK_CLOUD_EXTENSION=
AETHER_HOME_ASSISTANT_CLOUDLINK_SPOOL_CAPACITY=4096
AETHER_HOME_ASSISTANT_CLOUDLINK_MQTT_BROKER_HOST=
AETHER_HOME_ASSISTANT_CLOUDLINK_MQTT_BROKER_PORT=
AETHER_HOME_ASSISTANT_CLOUDLINK_MQTT_CLIENT_ID=
AETHER_HOME_ASSISTANT_CLOUDLINK_MQTT_TOPIC_PREFIX=
AETHER_HOME_ASSISTANT_CLOUDLINK_MQTT_USERNAME=
AETHER_HOME_ASSISTANT_CLOUDLINK_MQTT_PASSWORD_SECRET=
AETHER_HOME_ASSISTANT_CLOUDLINK_CREDENTIAL_ID=
AETHER_HOME_ASSISTANT_CLOUDLINK_CREDENTIAL_GENERATION=

# Optional governed control. Cloud command verification uses the public-key
# value below. Receipt signing reuses the CloudLink Gateway session key rather
# than injecting a second Edge private key. Policy/state paths use /app/data.
AETHER_HOME_ASSISTANT_CONTROL_CLOUD_EXTENSION=
AETHER_HOME_ASSISTANT_CONTROL_CLOUD_KEY_ID=
AETHER_HOME_ASSISTANT_CONTROL_CLOUD_PUBLIC_KEY=
AETHER_HOME_ASSISTANT_CONTROL_PROVIDER_TIMEOUT_MS=5000

# ============================================
# Logging
# ============================================

# Rust services log level (info, debug, trace)
# Supports filter syntax: info,aether_io=debug,aether_automation=trace
RUST_LOG=info

# Shared by aether-api and the direct services that verify governed access
# JWTs (io, automation, and alarm). Generate a unique value; never commit it:
#   openssl rand -hex 32
JWT_SECRET_KEY=

# Authenticates only aether-uplink when it forwards a cloud device command to
# aether-automation. Use a different random value from JWT_SECRET_KEY:
#   openssl rand -hex 32
AETHER_UPLINK_CONTROL_TOKEN=

# Development-only. Production must leave this false so callers cannot forge
# authoritative telemetry/signal values and trigger automation rules.
AETHER_ALLOW_SIMULATION_WRITES=false

# Required only while the users table is empty. The edge installer generates
# this value automatically. For a manual first start, provide at least 16 raw
# characters with no surrounding whitespace or control characters, then
# change the admin password and remove this line after the first login.
AETHER_BOOTSTRAP_ADMIN_PASSWORD=

# Anonymous account creation is disabled unless an operator opts in.
AETHER_ALLOW_PUBLIC_REGISTRATION=false

# Required only when enabling the optional postgres-storage profile. Leave it
# empty for the default embedded runtime; generate a unique value before opt-in.
#   openssl rand -hex 32
TIMESCALEDB_PASSWORD=
