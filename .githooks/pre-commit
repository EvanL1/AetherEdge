#!/usr/bin/env bash
set -e

echo "🦀 Running pre-commit checks..."

# Enforce no Chinese in output/log lines for backend/scripts
if [ -f scripts/ci/check-no-cn-output.sh ]; then
    bash scripts/ci/check-no-cn-output.sh
fi

# Color definitions
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check if any Rust files were changed
if ! git diff --cached --name-only | grep -q '\.rs$'; then
    echo "No Rust files changed, skipping Rust checks"
    echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
    exit 0
fi

echo "📋 Running Rust formatting check..."
if ! cargo fmt --all -- --check; then
    echo -e "${RED}❌ Rust formatting check failed!${NC}"
    echo "Run 'cargo fmt --all' to fix formatting issues"
    exit 1
fi

echo "🔍 Running clippy..."
if ! cargo clippy --all-targets --all-features -- -D warnings 2>/dev/null; then
    echo -e "${RED}❌ Clippy check failed!${NC}"
    echo "Running clippy again to show errors:"
    cargo clippy --all-targets --all-features -- -D warnings
    exit 1
fi

# Load .env file for test environment variables
if [ -f ".env" ]; then
    export $(cat .env | grep -E "^REDIS_URL=" | xargs)
fi

# Run unit tests only (integration tests require Redis, run separately)
echo "🧪 Running tests..."
if ! cargo test --workspace --lib --quiet -- --test-threads=1 2>/dev/null; then
    echo -e "${RED}❌ Tests failed!${NC}"
    echo "Running tests again to show errors:"
    cargo test --workspace --lib -- --test-threads=1
    exit 1
fi

echo "🔎 Checking for common issues..."

# Check println! usage (production code should use logging) - warning only, does not block commit
PRINTLN_FILES=$(git diff --cached --name-only | grep '\.rs$' | xargs grep -l "println!" 2>/dev/null | grep -v "src/bin/" | grep -v "examples/" | grep -v "tests/" || true)
if [ -n "$PRINTLN_FILES" ]; then
    echo -e "${YELLOW}⚠️  Info: Found println! in the following files (consider using tracing/log):${NC}"
    echo "$PRINTLN_FILES" | head -5
    if [ $(echo "$PRINTLN_FILES" | wc -l) -gt 5 ]; then
        echo "... and $(($(echo "$PRINTLN_FILES" | wc -l) - 5)) more files"
    fi
fi

# Check unwrap() usage - reasonable threshold
UNWRAP_COUNT=$(git diff --cached --name-only | grep '\.rs$' | xargs grep -n "\.unwrap()" 2>/dev/null | grep -v "tests/" | grep -v "test_" | grep -v "examples/" | wc -l || true)
if [ "$UNWRAP_COUNT" -gt 20 ]; then
    echo -e "${YELLOW}⚠️  Info: Many unwrap() calls detected ($UNWRAP_COUNT). Consider using ? or proper error handling where appropriate.${NC}"
fi

# Check TODO comments - only show newly added ones
NEW_TODOS=$(git diff --cached -U0 | grep '^+' | grep -E 'TODO|FIXME|HACK|XXX' | wc -l || true)
if [ "$NEW_TODOS" -gt 0 ]; then
    echo -e "${YELLOW}ℹ️  Info: Found $NEW_TODOS new TODO/FIXME comments in this commit${NC}"
fi

# Check for large files
LARGE_FILES=$(git diff --cached --name-only | xargs -I {} sh -c 'if [ -f "{}" ]; then wc -l "{}" | awk "\$1 > 1000 {print \$2}"; fi' 2>/dev/null || true)
if [ -n "$LARGE_FILES" ]; then
    echo -e "${YELLOW}⚠️  Warning: Large files detected (>1000 lines):${NC}"
    echo "$LARGE_FILES"
fi

# Check if Cargo.lock is being committed (library projects should not commit it)
if git diff --cached --name-only | grep -q "Cargo.lock" && [ -f "Cargo.toml" ]; then
    if grep -q '\[lib\]' Cargo.toml; then
        echo -e "${YELLOW}⚠️  Warning: Cargo.lock should not be committed for library projects${NC}"
    fi
fi

echo -e "${GREEN}✅ All pre-commit checks passed!${NC}"
